# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3001
FRONTEND_URL=http://localhost:3000
# Public URL the backend is reachable at — used to mint signed download URLs
PUBLIC_BACKEND_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Database (Microsoft SQL Server / Azure SQL)
# ---------------------------------------------------------------------------
# Local Docker container default: sa / Local-Dev-1234 / mike database.
# trustServerCertificate=true is needed for azure-sql-edge's self-signed cert.
# For Azure SQL, drop TrustServerCertificate and use:
#   Server=tcp:<server>.database.windows.net,1433;Database=mike;User Id=...;Password=...;Encrypt=true;TrustServerCertificate=false
DATABASE_URL=Server=localhost,1433;Database=mike;User Id=sa;Password=Local-Dev-1234;Encrypt=true;TrustServerCertificate=true

# ---------------------------------------------------------------------------
# Auth (sign your own random 32+ char secret)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
# DOWNLOAD_SIGNING_SECRET=optional-separate-secret-for-download-tokens

# ---------------------------------------------------------------------------
# Storage backend: "local" (filesystem), "azure" (Azure Blob), or "r2"
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local

# Local backend — relative to backend cwd, or an absolute path
LOCAL_STORAGE_DIR=uploads

# Azure Blob backend
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=mike

# Cloudflare R2 / S3-compatible (legacy)
# R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET_NAME=mike

# ---------------------------------------------------------------------------
# LLM providers (Azure OpenAI is the default; the other two are optional)
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-10-21

# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
